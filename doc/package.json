{
  "name": "doc",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "astro dev",
    "build": "node --run build:notes && node --run build:posts && node --run build:toc && playwright install && astro build",
    "build:notes": "node src/scripts/build-directory.ts notes",
    "build:posts": "node src/scripts/build-directory.ts posts",
    "build:toc": "node src/scripts/build-table-of-contents.ts",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.2",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/noto-sans": "^5.2.9",
    "@fontsource/ubuntu": "^5.2.7",
    "astro": "^6.4.4",
    "rehype-mermaid": "^3.0.0",
    "remark-toc": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "es-toolkit": "^1.47.0",
    "playwright": "^1.60.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "sharp": "^0.35.0",
    "typescript": "^6.0.3"
  }
}
