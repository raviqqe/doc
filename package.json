{
  "type": "module",
  "scripts": {
    "build": "node --run build:image && node --run build:slides && node --run build:tex && pnpm -r build",
    "build:image": "node --run build:mermaid && node --run build:drawio",
    "build:mermaid": "puppeteer browsers install chrome-headless-shell && tools/build_mermaid.sh",
    "build:drawio": "tools/build_drawio.sh",
    "build:slides": "node --run build:slides:html && node --run build:slides:pdf",
    "build:slides:html": "node --run marp -- --html",
    "build:slides:pdf": "node --run marp -- --pdf && tools/move_index_pdf.sh",
    "build:tex": "tools/build_tex.sh",
    "lint": "biome ci",
    "marp": "docker run --rm --init -v $PWD:/home/marp/app/ -e MARP_USER=$(id -u):$(id -g) marpteam/marp-cli --allow-local-files --input-dir slides --parallel",
    "marp:serve": "node --run marp -- --server"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@marp-team/marp-cli": "^4.2.3",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@raviqqe/biome-config": "^2.0.24",
    "puppeteer": "^24.35.0",
    "svgo": "^4.0.1"
  },
  "engines": {
    "node": ">=25.8.0"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
