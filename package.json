{
  "type": "module",
  "scripts": {
    "build": "node --run build:image && node --run build:slides && node --run build:tex && pnpm -r build",
    "build:image": "node --run build:mermaid && node --run build:drawio",
    "build:mermaid": "puppeteer browsers install chrome-headless-shell && tools/build_mermaid.sh",
    "build:drawio": "tools/build_drawio.sh",
    "build:slides": "node --run build:slides:html && node --run build:slides:pdf",
    "build:slides:html": "node --run marp -- --html",
    "build:slides:pdf": "node --run marp -- --pdf && tools/move_index_pdf.sh",
    "build:tex": "tools/build_tex.sh",
    "lint": "biome ci",
    "marp": "marp --allow-local-files --input-dir slides --parallel",
    "marp:serve": "node --run marp -- --server"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@marp-team/marp-cli": "^4.3.1",
    "@mermaid-js/mermaid-cli": "^11.14.0",
    "@raviqqe/biome-config": "^2.0.26",
    "puppeteer": "^24.42.0",
    "svgo": "^4.0.1"
  },
  "engines": {
    "node": "^25.9.0"
  },
  "packageManager": "pnpm@11.0.3+sha512.10448f2988933787c6699aef683174c741f6472ad91b7e3c8fe3e2bda57be8a0f7caf58949b8bc22e624578b3dc6e57876ba4c631928a1b84cc141e12c79bccd"
}
